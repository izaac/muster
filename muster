#!/usr/bin/env bash
# muster - wrangle a Rancher management cluster for any E2E framework.
#
# Thin dispatcher: parse the subcommand and flags, load config and the selected
# substrate driver, then route to the core libraries. All real work lives in
# lib/ (provider-blind) and drivers/ (the 4-verb substrate contract).

MUSTER_VERSION="0.1.0-dev"

# Resolve the install root from this script's location, following symlinks, so
# muster works whether it is run in-tree, via PATH, or through a symlink.
_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
  _dir="$(cd -P "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [ "${_self#/}" = "$_self" ] && _self="$_dir/$_self"
done
MUSTER_HOME="$(cd -P "$(dirname "$_self")" && pwd)"
export MUSTER_HOME

# shellcheck source=lib/util.sh
. "$MUSTER_HOME/lib/util.sh"
install_err_trap

usage() {
  cat >&2 <<'USAGE'
muster - bring up a Rancher management cluster for E2E testing.

Usage:
  muster <command> [flags]

Commands:
  up        Create/ensure a cluster and install Rancher, then wait + hand off.
  build-ui  Build a dashboard UI dist from the branch matching --version.
  wait      Run readiness gates against an existing instance.
  tunnel    Manage the cloudflared quick tunnel (external mode).
  warmup    Prime the provisioning controller to avoid the cold-start flake.
  down      Tear down the cluster and sweep tunnel + substrate state.
  env       Print the consumer handoff for the current instance.
  show      Print the resolved configuration (after config file + flags).
  version   Print the muster version.
  help      Show this help.

Flags:
  --provider <k3d|existing|docker>  Substrate driver (default: k3d).
  --instance <name>                 Instance id (default: e2e).
  --external                        Expose Rancher via a public tunnel.
  --repo <channel>                  Rancher channel (default: rancher-com-alpha):
                                    rancher-prime|rancher-latest|rancher-alpha|
                                    rancher-community|rancher-com-rc|rancher-com-alpha.
  --version <tag>                   Image tag: head or a version like 2.13 /
                                    2.13.4-rc1 (default: head).
  --prefer-staging                  Keep-fresh: when the tag is a rolling head
                                    tag (head / vX.Y-head) and the newest SUSE
                                    staging build (rancher-latest/-alpha) is
                                    newer by date, auto-promote the backend to
                                    it. A concrete --version pin always wins.
                                    Also honoured via PREFER_STAGING env.
  --password <secret>               Rancher bootstrap/admin password (default:
                                    RANCHER_PASSWORD env, else password1234).
  --out <env|cypress|json>          Handoff format (default: env).
  --dashboard-src <path>            rancher/dashboard checkout to build (build-ui).
  --dashboard-branch <name>         Force the UI branch (build-ui); default derives
                                    it from --version (head->master, vX.Y->release-X.Y).
  --dashboard-dist <path>           Prebuilt UI dist to mount over the pod UI (up),
                                    or where build-ui writes (default: <src>/dist).
  --node-bin <dir>                  Node bin dir to use for build-ui (escape hatch);
                                    default auto-selects Node from the branch.
  --kubeconfig <path>               Kubeconfig for the target cluster (existing
                                    provider; default: KUBECONFIG env).
  --rancher-host <hostname>         Hostname Rancher is served at (existing
                                    provider; default: RANCHER_HOST env).
  --config <path>                   Config file to source (default: ./config.sh).
  -h, --help                        Show this help.

Examples:
  muster up --provider k3d
  muster build-ui --dashboard-src ~/repos/dashboard --version head
  muster up --provider k3d --dashboard-dist ~/repos/dashboard/dist
  muster up --provider k3d --external --repo rancher-alpha --version head
  muster up --provider existing --kubeconfig ~/.kube/config --rancher-host rancher.example.com --out cypress
  muster down
USAGE
}

# Defaults; overridable by config file then flags.
PROVIDER="${PROVIDER:-k3d}"
INSTANCE="${INSTANCE:-e2e}"
EXTERNAL="${EXTERNAL:-false}"
RANCHER_REPO="${RANCHER_REPO:-rancher-com-alpha}"
RANCHER_IMAGE_TAG="${RANCHER_IMAGE_TAG:-head}"
PREFER_STAGING="${PREFER_STAGING:-false}"
RANCHER_PASSWORD="${RANCHER_PASSWORD:-password1234}"
OUT="${OUT:-env}"
DASHBOARD_SRC="${DASHBOARD_SRC:-}"
DASHBOARD_DIST="${DASHBOARD_DIST:-}"
DASHBOARD_BRANCH="${DASHBOARD_BRANCH:-}"
NODE_BIN="${NODE_BIN:-}"
KUBECONFIG="${KUBECONFIG:-}"
RANCHER_HOST="${RANCHER_HOST:-}"
CONFIG=""

CMD="${1:-help}"
if [ $# -gt 0 ]; then shift; fi

# A config file may pre-seed the defaults above before flags override them.
# Honour an explicit --config anywhere on the line by pre-scanning for it.
_args=("$@")
for ((i = 0; i < ${#_args[@]}; i++)); do
  if [ "${_args[i]}" = "--config" ]; then
    CONFIG="${_args[i + 1]:-}"
    break
  fi
done
[ -z "$CONFIG" ] && [ -r "./config.sh" ] && CONFIG="./config.sh"
if [ -n "$CONFIG" ]; then
  [ -r "$CONFIG" ] || die "config file not readable: $CONFIG"
  # shellcheck source=/dev/null
  . "$CONFIG"
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --provider)
      PROVIDER="${2:?--provider needs a value}"
      shift 2
      ;;
    --instance)
      INSTANCE="${2:?--instance needs a value}"
      shift 2
      ;;
    --external)
      EXTERNAL="true"
      shift
      ;;
    --version)
      RANCHER_IMAGE_TAG="${2:?--version needs a value}"
      shift 2
      ;;
    --repo)
      RANCHER_REPO="${2:?--repo needs a value}"
      shift 2
      ;;
    --prefer-staging)
      PREFER_STAGING="true"
      shift
      ;;
    --password)
      RANCHER_PASSWORD="${2:?--password needs a value}"
      shift 2
      ;;
    --out)
      OUT="${2:?--out needs a value}"
      shift 2
      ;;
    --dashboard-src)
      DASHBOARD_SRC="${2:?--dashboard-src needs a value}"
      shift 2
      ;;
    --dashboard-dist)
      DASHBOARD_DIST="${2:?--dashboard-dist needs a value}"
      shift 2
      ;;
    --dashboard-branch)
      DASHBOARD_BRANCH="${2:?--dashboard-branch needs a value}"
      shift 2
      ;;
    --node-bin)
      NODE_BIN="${2:?--node-bin needs a value}"
      shift 2
      ;;
    --kubeconfig)
      KUBECONFIG="${2:?--kubeconfig needs a value}"
      shift 2
      ;;
    --rancher-host)
      RANCHER_HOST="${2:?--rancher-host needs a value}"
      shift 2
      ;;
    --config)
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*) die "unknown flag: $1 (try 'muster help')" ;;
    *) die "unexpected argument: $1 (try 'muster help')" ;;
  esac
done

case "$PROVIDER" in
  k3d | existing | docker) ;;
  *) die "unknown provider: $PROVIDER (k3d|existing|docker)" ;;
esac
case "$OUT" in
  env | cypress | json) ;;
  *) die "unknown --out: $OUT (env|cypress|json)" ;;
esac
case "$RANCHER_REPO" in
  rancher-prime | rancher-latest | rancher-alpha | rancher-community | rancher-com-rc | rancher-com-alpha) ;;
  *) die "unknown --repo: $RANCHER_REPO (rancher-prime|rancher-latest|rancher-alpha|rancher-community|rancher-com-rc|rancher-com-alpha)" ;;
esac

export INSTANCE EXTERNAL RANCHER_REPO RANCHER_IMAGE_TAG OUT RANCHER_PASSWORD
export PREFER_STAGING
export DASHBOARD_SRC DASHBOARD_DIST DASHBOARD_BRANCH NODE_BIN KUBECONFIG RANCHER_HOST

load_core() {
  # shellcheck source=lib/download.sh
  . "$MUSTER_HOME/lib/download.sh"
  # shellcheck source=lib/helm.sh
  . "$MUSTER_HOME/lib/helm.sh"
  # shellcheck source=lib/gates.sh
  . "$MUSTER_HOME/lib/gates.sh"
  # shellcheck source=lib/tunnel.sh
  . "$MUSTER_HOME/lib/tunnel.sh"
  # shellcheck source=lib/external.sh
  . "$MUSTER_HOME/lib/external.sh"
  # shellcheck source=lib/warmup.sh
  . "$MUSTER_HOME/lib/warmup.sh"
  # shellcheck source=lib/handoff.sh
  . "$MUSTER_HOME/lib/handoff.sh"
  # shellcheck source=lib/buildui.sh
  . "$MUSTER_HOME/lib/buildui.sh"
  # shellcheck source=lib/node.sh
  . "$MUSTER_HOME/lib/node.sh"
  # shellcheck source=/dev/null
  . "$MUSTER_HOME/drivers/${PROVIDER}.sh"
}

# High-level command flows are assembled in Phase 1+ as the libs land.
cmd_up() {
  if [ "$PROVIDER" = existing ] && is_true "${EXTERNAL:-}"; then
    die "existing provider does not support --external (RANCHER_HOST is already reachable)"
  fi
  local tunnel_url=""
  if is_true "${EXTERNAL:-}"; then
    tunnel_url="$(tunnel_up)"
    export EXTERNAL_HOSTNAME="${tunnel_url#https://}"
  fi

  driver_up
  local kc host
  kc="$(driver_kubeconfig)"
  host="$(driver_endpoint)"

  # A driver that ships Rancher itself (docker standalone: the container IS
  # rancher) declares driver_installs_rancher; the core then skips the
  # helm chart install. k3d/existing leave it undefined and get helm.
  if ! declare -F driver_installs_rancher >/dev/null || ! driver_installs_rancher; then
    [ -n "${DASHBOARD_DIST:-}" ] \
      && log_info "mounting prebuilt UI dist over the pod: $DASHBOARD_DIST"
    helm_resolve_version
    helm_install_rancher "$kc" "$host"
  else
    [ -n "${DASHBOARD_DIST:-}" ] \
      && log_info "mounted prebuilt UI dist over the container UI: $DASHBOARD_DIST"
  fi
  gates_wait

  export MUSTER_HOSTNAME="$host" MUSTER_KUBECONFIG="$kc" MUSTER_PASSWORD="$RANCHER_PASSWORD"
  handoff_write "$OUT"
}
cmd_wait() {
  gates_wait
  local kc host
  kc="$(driver_kubeconfig)"
  host="$(driver_endpoint)"
  export MUSTER_HOSTNAME="$host" MUSTER_KUBECONFIG="$kc" MUSTER_PASSWORD="$RANCHER_PASSWORD"
  handoff_write "$OUT"
}
cmd_tunnel() { tunnel_up; }
cmd_warmup() {
  local kc
  kc="$(driver_kubeconfig)"
  warmup_provisioning "$kc"
}
cmd_down() {
  tunnel_down
  driver_down
}
cmd_build_ui() { buildui_run; }

case "$CMD" in
  version)
    echo "muster $MUSTER_VERSION"
    ;;
  show)
    cat <<EOF
provider=$PROVIDER
instance=$INSTANCE
external=$EXTERNAL
repo=$RANCHER_REPO
version=$RANCHER_IMAGE_TAG
out=$OUT
dashboard_src=${DASHBOARD_SRC:-<none>}
dashboard_branch=${DASHBOARD_BRANCH:-<derived>}
dashboard_dist=${DASHBOARD_DIST:-<none>}
node_bin=${NODE_BIN:-<auto>}
kubeconfig=${KUBECONFIG:-<none>}
rancher_host=${RANCHER_HOST:-<none>}
config=${CONFIG:-<none>}
EOF
    ;;
  help | -h | --help)
    usage
    ;;
  up)
    load_core
    cmd_up
    ;;
  build-ui)
    load_core
    cmd_build_ui
    ;;
  wait)
    load_core
    cmd_wait
    ;;
  tunnel)
    load_core
    cmd_tunnel
    ;;
  warmup)
    load_core
    cmd_warmup
    ;;
  down)
    load_core
    cmd_down
    ;;
  env)
    load_core
    . "$MUSTER_HOME/lib/tunnel.sh"
    if is_true "${EXTERNAL:-}"; then
      t_url="$(tunnel_url)"
      [ -n "$t_url" ] && export EXTERNAL_HOSTNAME="${t_url#https://}"
    fi
    kc="$(driver_kubeconfig)"
    host="$(driver_endpoint)"
    export MUSTER_HOSTNAME="$host" MUSTER_KUBECONFIG="$kc" MUSTER_PASSWORD="$RANCHER_PASSWORD"
    handoff_write "$OUT"
    ;;
  *)
    log_err "unknown command: $CMD"
    usage
    exit 2
    ;;
esac
